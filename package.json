{
  "name": "claude-desktop",
  "version": "1.0.1",
  "description": "Claude AI – Native Desktop App für Linux",
  "main": "main.js",
  "homepage": "https://github.com/simon-gettkandt/claude-desktop",
  "author": {
    "name": "Simon Gettkandt",
    "email": "simon@gettkandt.de"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux",
    "build-deb": "electron-builder --linux deb",
    "build-appimage": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.claude.desktop",
    "productName": "Claude Desktop",
    "linux": {
      "target": ["deb"],
      "icon": "icon.png",
      "category": "Utility",
      "synopsis": "Claude AI Desktop Client",
      "description": "Eine schnelle, native Desktop-App für Claude AI",
      "maintainer": "Simon Gettkandt"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}
