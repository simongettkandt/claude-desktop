{
  "name": "claude-desktop",
  "version": "1.3.0-beta.1",
  "description": "Claude AI – Native Desktop App für Linux",
  "main": "main.js",
  "homepage": "https://github.com/simongettkandt/claude-ai-desktop-app",
  "author": {
    "name": "Simon Gettkandt",
    "email": "simon@gettkandt.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/simongettkandt/claude-ai-desktop-app.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux",
    "build-appimage": "electron-builder --linux AppImage",
    "build-deb": "electron-builder --linux deb"
  },
  "build": {
    "appId": "com.claude.desktop",
    "productName": "Claude Desktop",
    "publish": {
      "provider": "github",
      "owner": "simongettkandt",
      "repo": "claude-ai-desktop-app"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "icon.png",
      "category": "Utility",
      "synopsis": "Claude AI Desktop Client",
      "description": "Eine schnelle, native Desktop-App für Claude AI",
      "maintainer": "Simon Gettkandt"
    },
    "electronLanguages": [
      "en-US",
      "de"
    ],
    "compression": "maximum",
    "asar": true,
    "files": [
      "main.js",
      "preload-tabbar.js",
      "preload-settings.js",
      "preload-quickprompt.js",
      "preload-whatsnew.js",
      "inject/**/*",
      "icon.png",
      "icon-original.png",
      "package.json",
      "node_modules/**/*",
      "!node_modules/*/{test,tests,__tests__,docs,doc,example,examples,benchmark,benchmarks}/**",
      "!node_modules/**/*.{md,markdown,ts,map,d.ts,coffee,bak,log,h,c,cc,cpp,gyp,gypi,Makefile,mk}",
      "!node_modules/**/{LICENSE,license,LICENCE,licence,CHANGELOG,changelog,HISTORY,history,AUTHORS,CONTRIBUTORS,NOTICE,README,readme}*",
      "!node_modules/**/{.github,.idea,.vscode,.nyc_output,.eslintrc*,.prettierrc*,.editorconfig,.travis.yml,.gitignore,.gitattributes,.npmignore,tsconfig*.json,jest.config*,karma.conf*,webpack.config*,rollup.config*,gulpfile*,Gruntfile*}",
      "!**/*.{md,ts,map,d.ts}"
    ],
    "appImage": {
      "artifactName": "Claude-Desktop-${version}.AppImage"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  }
}
