{
  "name": "claude-desktop",
  "version": "1.1.3",
  "description": "Claude AI – Native Desktop App für Linux",
  "main": "main.js",
  "homepage": "https://github.com/simongettkandt/claude-ai-desktop-app",
  "author": {
    "name": "Simon Gettkandt",
    "email": "simon@gettkandt.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/simongettkandt/claude-ai-desktop-app.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux",
    "build-appimage": "electron-builder --linux AppImage",
    "build-deb": "electron-builder --linux deb"
  },
  "build": {
    "appId": "com.claude.desktop",
    "productName": "Claude Desktop",
    "publish": {
      "provider": "github",
      "owner": "simongettkandt",
      "repo": "claude-ai-desktop-app"
    },
    "files": [
      "main.js",
      "preload-tabbar.js",
      "icon.png",
      "package.json",
      "node_modules/**/*",
      "!node_modules/*/{test,tests,__tests__,docs,doc,example,examples}/**",
      "!**/*.{md,ts,map,d.ts}"
    ],
    "linux": {
      "target": ["AppImage"],
      "icon": "icon.png",
      "category": "Utility",
      "synopsis": "Claude AI Desktop Client",
      "description": "Eine schnelle, native Desktop-App für Claude AI",
      "maintainer": "Simon Gettkandt"
    },
    "appImage": {
      "artifactName": "Claude-Desktop-${version}.AppImage"
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}
